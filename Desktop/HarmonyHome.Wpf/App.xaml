<Application x:Class="HarmonyHome.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HarmonyHome.Wpf"
             StartupUri="Views/LoginView.xaml">

    <Application.Resources>

        <!-- colores base -->
        <SolidColorBrush x:Key="ColorFondoApp" Color="#F6F8F4"/>
        <SolidColorBrush x:Key="ColorPanel" Color="#FFFFFF"/>

        <!-- color de cabecera y menú lateral -->
        <SolidColorBrush x:Key="ColorVerdePanel" Color="#DDF6DF"/>

        <!-- texto y bordes -->
        <SolidColorBrush x:Key="ColorTextoPrincipal" Color="#2F3A2F"/>
        <SolidColorBrush x:Key="ColorTextoSecundario" Color="#6B756B"/>
        <SolidColorBrush x:Key="ColorBorde" Color="#D8DED2"/>

        <!-- color numérico del dashboard -->
        <SolidColorBrush x:Key="ColorPrincipal" Color="#7BAE7F"/>

        <!-- botón normal gris claro -->
        <SolidColorBrush x:Key="ColorBotonNormal" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="ColorBotonNormalBorde" Color="#D1D5DB"/>

        <!-- botón operación azul muy claro -->
        <SolidColorBrush x:Key="ColorBotonOperacion" Color="#E3F0FF"/>
        <SolidColorBrush x:Key="ColorBotonOperacionBorde" Color="#BFD7F3"/>
        <SolidColorBrush x:Key="ColorTextoBotonOperacion" Color="#1F3A5F"/>

        <!-- botón peligro rojo muy claro -->
        <SolidColorBrush x:Key="ColorBotonPeligro" Color="#FBE1E1"/>
        <SolidColorBrush x:Key="ColorBotonPeligroBorde" Color="#E8A6A6"/>
        <SolidColorBrush x:Key="ColorTextoBotonPeligro" Color="#7A2E2E"/>

        <!-- tarjetas -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ColorPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- botón normal -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource ColorBotonNormal}"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTextoPrincipal}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorBotonNormalBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- botón operación -->
        <Style x:Key="BotonOperacion" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource ColorBotonOperacion}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorBotonOperacionBorde}"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTextoBotonOperacion}"/>
        </Style>

        <!-- botón peligro -->
        <Style x:Key="BotonPeligro" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource ColorBotonPeligro}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorBotonPeligroBorde}"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTextoBotonPeligro}"/>
        </Style>

        <!-- botón menú lateral -->
        <Style x:Key="BotonMenu" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTextoPrincipal}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- textbox -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- password -->
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- combobox -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- datagrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorBorde}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
        </Style>

        <!-- mensajes -->
        <Style x:Key="TextoMensaje" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ColorTextoSecundario}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

    </Application.Resources>
</Application>