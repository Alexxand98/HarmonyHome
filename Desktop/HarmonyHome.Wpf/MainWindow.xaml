<Window x:Class="HarmonyHome.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HarmonyHome - Módulo Logístico"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Background="DarkSeaGreen">

        <Border Background="White"
                CornerRadius="20"
                Padding="20"
                Width="500"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="HarmonyHome"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Módulo de almacén"
                           FontSize="14"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                

                <Button Content="Entrar"
                        Height="35"
                        Width="120"
                        HorizontalAlignment="Center"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>