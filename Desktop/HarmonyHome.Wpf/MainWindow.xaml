<Window x:Class="HarmonyHome.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="HarmonyHome - Módulo Logístico"
        Height="720"
        Width="1150"
        MinHeight="650"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource ColorFondoApp}">

    <Grid Background="{StaticResource ColorFondoApp}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="0,0,1,0"
                Padding="18">

            <DockPanel LastChildFill="True">

                <StackPanel DockPanel.Dock="Top">

                    <TextBlock Text="HarmonyHome"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoPrincipal}"
                               Margin="0,0,0,4"/>

                    <TextBlock x:Name="TxtModuloApp"
                               Text="Módulo logístico"
                               FontSize="13"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               Margin="0,0,0,24"/>

                    <TextBlock Text="INVENTARIO"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               Margin="0,0,0,8"/>

                    <Button x:Name="BtnProductos"
                            Content="Productos"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnProductos_Click"/>

                    <Button x:Name="BtnStock"
                            Content="Stock"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnStock_Click"/>

                    <Button x:Name="BtnProductosBajoStock"
                            Content="Productos stock bajo"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnProductosBajoStock_Click"/>

                    <Button x:Name="BtnUbicaciones"
                            Content="Ubicaciones"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnUbicaciones_Click"/>

                    <Button x:Name="BtnMovimientos"
                            Content="Movimientos"
                            Style="{StaticResource BotonMenu}"
                            Margin="0,0,0,20"
                            Click="BtnMovimientos_Click"/>

                    <TextBlock Text="OPERACIONES"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               Margin="0,0,0,8"/>

                    <Button x:Name="BtnOrdenesRecogida"
                            Content="Órdenes recogida"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnOrdenesRecogida_Click"/>

                    <Button x:Name="BtnOrdenesReposicion"
                            Content="Órdenes reposición"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnOrdenesReposicion_Click"/>

                    <Button x:Name="BtnDemarca"
                            Content="Demarcas"
                            Style="{StaticResource BotonMenu}"
                            Margin="0,0,0,20"
                            Click="BtnDemarca_Click"/>

                    <TextBlock Text="ADMINISTRACIÓN"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               Margin="0,0,0,8"/>

                    <Button x:Name="BtnGestionProductos"
                            Content="Gestión productos"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnGestionProductos_Click"/>

                    <Button x:Name="BtnGestionUbicaciones"
                            Content="Gestión ubicaciones"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnGestionUbicaciones_Click"/>

                    <Button x:Name="BtnGestionLogisticos"
                            Content="Gestión logísticos"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnGestionLogisticos_Click"/>

                </StackPanel>

                <Button x:Name="BtnCerrarSesion"
                        Content="Cerrar sesión"
                        Height="38"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource BotonPeligro}"
                        Click="BtnCerrarSesion_Click"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource ColorVerdePanel}"
                    CornerRadius="12"
                    Padding="18"
                    BorderBrush="{StaticResource ColorBorde}"
                    BorderThickness="1"
                    Margin="0,0,0,18">

                <StackPanel>
                    <TextBlock Text="Panel logístico"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoPrincipal}"/>

                    <TextBlock Text="Resumen general de almacén, stock y operaciones logísticas"
                               FontSize="14"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <UniformGrid Grid.Row="1"
                         Columns="4"
                         Margin="0,0,0,18">

                <Border Style="{StaticResource CardPanel}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Recogidas pendientes"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtRecogidasPendientes"
                                   Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrincipal}"/>

                        <TextBlock Text="Órdenes por asignar"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardPanel}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Reposiciones pendientes"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtReposicionesPendientes"
                                   Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrincipal}"/>

                        <TextBlock Text="Solicitudes desde tienda"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardPanel}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Productos bajo stock"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtProductosBajoStock"
                                   Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#8A6D1D"/>

                        <TextBlock Text="Stock total bajo mínimo"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Text="Movimientos recientes"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="13"/>

                        <TextBlock x:Name="TxtMovimientosRecientes"
                                   Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrincipal}"/>

                        <TextBlock Text="Últimos 14 de hoy"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.4*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardPanel}"
                        Margin="0,0,18,0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Actividad logística"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ColorTextoPrincipal}"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="Movimientos de stock registrados durante la fecha de trabajo"
                                       FontSize="14"
                                       Foreground="{StaticResource ColorTextoSecundario}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>
                        </StackPanel>

                        <DataGrid x:Name="TablaUltimosMovimientos"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MinHeight="360"
                                  Margin="0,0,0,16">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Producto"
                                                    Binding="{Binding ProductoNombre}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Tipo"
                                                    Binding="{Binding TipoMovimientoNombre}"
                                                    Width="150"/>

                                <DataGridTextColumn Header="Cantidad"
                                                    Binding="{Binding Cantidad}"
                                                    Width="90"/>

                                <DataGridTextColumn Header="Origen"
                                                    Binding="{Binding UbicacionOrigenNombre}"
                                                    Width="160"/>

                                <DataGridTextColumn Header="Destino"
                                                    Binding="{Binding UbicacionDestinoNombre}"
                                                    Width="160"/>

                                <DataGridTextColumn Header="Fecha"
                                                    Binding="{Binding Fecha}"
                                                    Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2"
                                Background="{StaticResource ColorPanel}"
                                BorderBrush="{StaticResource ColorBorde}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16"
                                MinHeight="95">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Estado del sistema"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"
                                           Margin="0,0,0,12"/>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Usuario conectado"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ColorTextoSecundario}"/>

                                        <TextBlock x:Name="TxtUsuario"
                                                   Text="Usuario"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource ColorTextoPrincipal}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Rol activo"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ColorTextoSecundario}"/>

                                        <TextBlock x:Name="TxtRol"
                                                   Text="Rol"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource ColorTextoPrincipal}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Fecha de trabajo"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ColorTextoSecundario}"/>

                                        <TextBlock Text="28/05/2026"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource ColorTextoPrincipal}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Versión"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ColorTextoSecundario}"/>

                                        <TextBlock x:Name="TxtVersionApp"
                                                   Text="HarmonyHome WPF v1.0"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource ColorTextoPrincipal}"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource CardPanel}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="330"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Estados de recogida"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ColorTextoPrincipal}"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="Distribución de órdenes de recogida por estado"
                                       FontSize="14"
                                       Foreground="{StaticResource ColorTextoSecundario}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>
                        </StackPanel>

                        <lvc:PieChart x:Name="GraficoEstadosOrdenes"
                                      Grid.Row="1"
                                      Width="260"
                                      Height="260"
                                      LegendPosition="Hidden"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="0,0,0,8"/>

                        <StackPanel Grid.Row="2"
                                    HorizontalAlignment="Center"
                                    Width="280"
                                    Margin="0,8,0,0">

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="#2196F3"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>

                                <TextBlock Grid.Column="1"
                                           Text="Pendientes"
                                           FontSize="14"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                                <TextBlock x:Name="TxtGraficoPendientes"
                                           Grid.Column="2"
                                           Text="0"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="#F44336"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>

                                <TextBlock Grid.Column="1"
                                           Text="Asignadas"
                                           FontSize="14"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                                <TextBlock x:Name="TxtGraficoAsignadas"
                                           Grid.Column="2"
                                           Text="0"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="#8BC34A"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>

                                <TextBlock Grid.Column="1"
                                           Text="En preparación"
                                           FontSize="14"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                                <TextBlock x:Name="TxtGraficoEnPreparacion"
                                           Grid.Column="2"
                                           Text="0"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="#00BCD4"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>

                                <TextBlock Grid.Column="1"
                                           Text="Finalizadas"
                                           FontSize="14"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                                <TextBlock x:Name="TxtGraficoFinalizadas"
                                           Grid.Column="2"
                                           Text="0"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="#3F51B5"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>

                                <TextBlock Grid.Column="1"
                                           Text="Canceladas"
                                           FontSize="14"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                                <TextBlock x:Name="TxtGraficoCanceladas"
                                           Grid.Column="2"
                                           Text="0"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>