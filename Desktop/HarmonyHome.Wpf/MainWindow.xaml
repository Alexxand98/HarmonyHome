<Window x:Class="HarmonyHome.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HarmonyHome - Modulo Logistico"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Background="DarkSeaGreen">

        <Rectangle Height="85"
                   Fill="White"
                   Stroke="Black"
                   VerticalAlignment="Top"/>

        <TextBlock Text="HarmonyHome"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="25,18,0,0"/>

        <TextBlock Text="Aplicacion de almacen"
                   FontSize="14"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="27,52,0,0"/>

        <TextBlock x:Name="TxtUsuario"
                   Text="Usuario"
                   FontSize="13"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,25,25,0"/>

        <TextBlock x:Name="TxtRol"
                   Text="Rol"
                   FontSize="13"
                   FontWeight="DemiBold"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,48,25,0"/>

        <StackPanel Background="White"
                    Width="170"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Margin="0,85,0,0">

            <Button x:Name="BtnProductos"
                    Content="Productos"
                    Height="38"
                    Margin="15,20,15,10"
                    Click="BtnProductos_Click"/>
            
            <Button x:Name="BtnGestionProductos"
                Content="Gestión productos"
                Height="38"
                Margin="15,0,15,10"
                Click="BtnGestionProductos_Click"/>

            <Button x:Name="BtnUbicaciones"
                    Content="Ubicaciones"
                    Height="38"
                    Margin="15,0,15,10"  
                    Click="BtnUbicaciones_Click"/>

            <Button x:Name="BtnServidor"
                    Content="Servidor"
                    Height="38"
                    Margin="15,0,15,10"
                    Click="BtnServerInfo_Click"/>

            <Button x:Name="BtnCerrarSesion"
                    Content="Cerrar sesion"
                    Height="38"
                    Margin="15,25,15,10"
                    Click="BtnCerrarSesion_Click"/>

        </StackPanel>

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="150,70,0,0">

            <TextBlock Text="Aplicacion de almacen"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Selecciona una opcion del menu"
                       FontSize="15"
                       HorizontalAlignment="Center"/>

        </StackPanel>

    </Grid>
</Window>