<Window x:Class="HarmonyHome.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HarmonyHome - Módulo Logístico"
        Height="720"
        Width="1150"
        MinHeight="650"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Background="{StaticResource ColorFondoApp}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENÚ LATERAL -->
        <Border Grid.Column="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="0,0,1,0"
                Padding="18">

            <DockPanel LastChildFill="True">

                <StackPanel DockPanel.Dock="Top">

                    <TextBlock Text="HarmonyHome"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoPrincipal}"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="Módulo logístico"
                               FontSize="13"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               Margin="0,0,0,24"/>

                    <TextBlock Text="INVENTARIO"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               Margin="0,0,0,8"/>

                    <Button x:Name="BtnProductos"
                            Content="Productos"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnProductos_Click"/>

                    <Button x:Name="BtnUbicaciones"
                            Content="Ubicaciones"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnUbicaciones_Click"/>

                    <Button x:Name="BtnStock"
                            Content="Stock"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnStock_Click"/>

                    <Button x:Name="BtnMovimientos"
                            Content="Movimientos"
                            Style="{StaticResource BotonMenu}"
                            Margin="0,0,0,20"
                            Click="BtnMovimientos_Click"/>

                    <TextBlock Text="OPERACIONES"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               Margin="0,0,0,8"/>

                    <Button x:Name="BtnDemarca"
                            Content="Demarca"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnDemarca_Click"/>

                    <Button x:Name="BtnOrdenesRecogida"
                            Content="Órdenes recogida"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnOrdenesRecogida_Click"/>

                    <Button x:Name="BtnOrdenesReposicion"
                            Content="Órdenes reposición"
                            Style="{StaticResource BotonMenu}"
                            Margin="0,0,0,20"
                            Click="BtnOrdenesReposicion_Click"/>

                    <TextBlock Text="ADMINISTRACIÓN"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               Margin="0,0,0,8"/>

                    <Button x:Name="BtnGestionProductos"
                            Content="Gestión productos"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnGestionProductos_Click"/>

                    <Button x:Name="BtnGestionUbicaciones"
                            Content="Gestión ubicaciones"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnGestionUbicaciones_Click"/>

                    <Button x:Name="BtnGestionLogisticos"
                            Content="Gestión logísticos"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnGestionLogisticos_Click"/>

                    <Button x:Name="BtnServidor"
                            Content="Servidor"
                            Style="{StaticResource BotonMenu}"
                            Click="BtnServerInfo_Click"/>

                </StackPanel>

                <Button x:Name="BtnCerrarSesion"
                        Content="Cerrar sesión"
                        Height="38"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource BotonPeligro}"
                        Click="BtnCerrarSesion_Click"/>
            </DockPanel>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Column="1" Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- CABECERA -->
            <Border Background="{StaticResource ColorPanel}"
                    CornerRadius="12"
                    Padding="18"
                    BorderBrush="{StaticResource ColorBorde}"
                    BorderThickness="1"
                    Margin="0,0,0,18">

                <StackPanel>
                    <TextBlock Text="Panel logístico"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoPrincipal}"/>

                    <TextBlock Text="Resumen general de almacén, stock y operaciones logísticas."
                               FontSize="14"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- TARJETAS RESUMEN -->
            <UniformGrid Grid.Row="1"
                         Columns="4"
                         Margin="0,0,0,18">

                <Border Style="{StaticResource CardPanel}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Recogidas pendientes"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="13"/>

                        <TextBlock Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrincipal}"/>

                        <TextBlock Text="Órdenes por asignar"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardPanel}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Reposiciones pendientes"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="13"/>

                        <TextBlock Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrincipal}"/>

                        <TextBlock Text="Solicitudes desde tienda"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardPanel}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Productos bajo stock"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="13"/>

                        <TextBlock Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#8A6D1D"/>

                        <TextBlock Text="Stock total bajo mínimo"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Text="Movimientos recientes"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="13"/>

                        <TextBlock Text="0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrincipal}"/>

                        <TextBlock Text="Últimas operaciones"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- PANEL CENTRAL -->
            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- ACTIVIDAD LOGÍSTICA -->
                <Border Grid.Column="0"
                        Style="{StaticResource CardPanel}"
                        Margin="0,0,18,0">

                    <StackPanel>
                        <TextBlock Text="Actividad logística"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorTextoPrincipal}"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Resumen visual de órdenes, productos bajo stock y operaciones recientes."
                                   FontSize="14"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <DataGrid AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Height="260">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tipo" Width="150"/>
                                <DataGridTextColumn Header="Estado" Width="130"/>
                                <DataGridTextColumn Header="Descripción" Width="*"/>
                                <DataGridTextColumn Header="Fecha" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ESTADO DEL SISTEMA -->
                <Border Grid.Column="1"
                        Style="{StaticResource CardPanel}">

                    <StackPanel>
                        <TextBlock Text="Estado del sistema"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorTextoPrincipal}"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Información de la sesión actual"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   FontSize="14"
                                   Margin="0,0,0,18"/>

                        <TextBlock Text="Usuario conectado"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ColorTextoSecundario}"/>

                        <TextBlock x:Name="TxtUsuario"
                                   Text="Usuario"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorTextoPrincipal}"
                                   Margin="0,2,0,14"/>

                        <TextBlock Text="Rol activo"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ColorTextoSecundario}"/>

                        <TextBlock x:Name="TxtRol"
                                   Text="Rol"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorTextoPrincipal}"
                                   Margin="0,2,0,14"/>

                        <TextBlock Text="Fecha de trabajo"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ColorTextoSecundario}"/>

                        <TextBlock Text="28/05/2026"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorTextoPrincipal}"
                                   Margin="0,2,0,14"/>

                        <TextBlock Text="Versión"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ColorTextoSecundario}"/>

                        <TextBlock Text="HarmonyHome WPF v1.0"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorTextoPrincipal}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>