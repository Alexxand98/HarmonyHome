<Window x:Class="HarmonyHome.Wpf.Views.AltaStockView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="Añadir stock"
        Height="500"
        Width="620"
        MinHeight="480"
        MinWidth="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="22"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Añadir stock"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Registra una entrada de stock para un producto en una ubicación de almacén."
                           FontSize="14"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardPanel}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Datos del stock"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,14"/>

                <StackPanel Grid.Row="1"
                            Margin="0,0,0,10">

                    <TextBlock Text="Producto"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <ComboBox x:Name="CmbProducto"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              Text="Seleccione un producto"
                              IsEditable="True"
                              IsReadOnly="True"
                              Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="0,0,0,10">

                    <TextBlock Text="Ubicación"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <ComboBox x:Name="CmbUbicacion"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              Text="Seleccione una ubicación"
                              IsEditable="True"
                              IsReadOnly="True"
                              Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="Cantidad"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <TextBox x:Name="TxtCantidad"
                             Margin="0,4,0,16"/>

                    <Button x:Name="BtnGuardar"
                            Content="Guardar stock"
                            Width="130"
                            Style="{StaticResource BotonOperacion}"
                            HorizontalAlignment="Left"
                            Click="BtnGuardar_Click"/>

                    <TextBlock x:Name="TxtMensaje"
                               Text=""
                               Foreground="{StaticResource ColorTextoSecundario}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>