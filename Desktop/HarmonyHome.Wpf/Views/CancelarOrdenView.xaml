<Window x:Class="HarmonyHome.Wpf.Views.CancelarOrdenView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cancelar orden"
        Height="335"
        Width="460"
        MinHeight="335"
        MinWidth="460"
        MaxHeight="335"
        MaxWidth="460"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="16"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="86"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,10">

            <StackPanel>
                <TextBlock Text="Cancelar orden"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Indica el motivo de cancelación"
                           FontSize="13"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   Text="Motivo de cancelación"
                   Foreground="{StaticResource ColorTextoSecundario}"
                   VerticalAlignment="Center"/>

        <TextBox x:Name="TxtMotivo"
                 Grid.Row="2"
                 Height="80"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,10"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

            <Button x:Name="BtnAceptar"
                    Content="Aceptar"
                    Width="95"
                    Style="{StaticResource BotonOperacion}"
                    Click="BtnAceptar_Click"/>

            <Button x:Name="BtnCancelar"
                    Content="Cancelar"
                    Width="95"
                    Style="{StaticResource BotonPeligro}"
                    Click="BtnCancelar_Click"/>
        </StackPanel>

        <TextBlock x:Name="TxtMensaje"
                   Grid.Row="4"
                   Text=""
                   Style="{StaticResource TextoMensaje}"/>

    </Grid>
</Window>