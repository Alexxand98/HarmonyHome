<Window x:Class="HarmonyHome.Wpf.Views.DemarcaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="DemarcaView" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">


    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="Registrar demarca"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Producto"/>
            <ComboBox x:Name="CmbProducto"
                      DisplayMemberPath="Nombre"
                      SelectedValuePath="Id"
                      Margin="0,0,0,10"/>

            <TextBlock Text="Ubicación"/>
            <ComboBox x:Name="CmbUbicacion"
                      DisplayMemberPath="Nombre"
                      SelectedValuePath="Id"
                      Margin="0,0,0,10"/>

            <TextBlock Text="Cantidad"/>
            <TextBox x:Name="TxtCantidad"
                     Margin="0,0,0,10"/>

            <TextBlock Text="Motivo"/>
            <TextBox x:Name="TxtMotivo"
                     Height="70"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Margin="0,0,0,15"/>

            <Button x:Name="BtnRegistrar"
                    Content="Registrar demarca"
                    Width="140"
                    Height="35"
                    HorizontalAlignment="Left"
                    Click="BtnRegistrar_Click"/>

            <TextBlock x:Name="TxtMensaje"
                       Text=""
                       Foreground="Gray"
                       TextWrapping="Wrap"
                       Margin="0,15,0,0"/>

        </StackPanel>
    </Grid>
</Window>