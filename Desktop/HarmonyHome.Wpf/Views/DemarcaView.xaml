<Window x:Class="HarmonyHome.Wpf.Views.DemarcaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="Registrar demarca"
        Height="610"
        Width="760"
        MinHeight="580"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="18"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,12">

            <StackPanel>
                <TextBlock Text="Registrar demarca"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Retira stock no vendible o defectuoso indicando producto, ubicación, cantidad y motivo."
                           FontSize="13"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardPanel}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.ColumnSpan="3"
                           Text="Datos de la demarca"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,0,10">

                    <TextBlock Text="Producto"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <ComboBox x:Name="CmbProducto"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              Text="Seleccione un producto"
                              IsEditable="True"
                              IsReadOnly="True"
                              Margin="0,4,0,0"
                              SelectionChanged="CmbProducto_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,0,0,10">

                    <TextBlock Text="Ubicación"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <ComboBox x:Name="CmbUbicacion"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              Text="Seleccione una ubicación"
                              IsEditable="True"
                              IsReadOnly="True"
                              Margin="0,4,0,0"
                              SelectionChanged="CmbUbicacion_SelectionChanged"/>

                    <TextBlock x:Name="TxtStockDisponible"
                               Text="Stock disponible: -"
                               FontSize="12"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="0"
                            Width="180"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10">

                    <TextBlock Text="Cantidad"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <TextBox x:Name="TxtCantidad"
                             Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Grid.ColumnSpan="3">

                    <TextBlock Text="Motivo"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <TextBox x:Name="TxtMotivo"
                             Height="75"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Margin="0,4,0,12"/>

                    <Button x:Name="BtnRegistrar"
                            Content="Registrar demarca"
                            Width="150"
                            Style="{StaticResource BotonOperacion}"
                            HorizontalAlignment="Left"
                            Click="BtnRegistrar_Click"/>

                    <TextBlock x:Name="TxtMensaje"
                               Text=""
                               Foreground="{StaticResource ColorTextoSecundario}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>