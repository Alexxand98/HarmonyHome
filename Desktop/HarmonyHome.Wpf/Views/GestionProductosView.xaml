<Window x:Class="HarmonyHome.Wpf.Views.GestionProductosView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="Gestion Productos" Height="500" Width="1000"
        WindowStartupLocation="CenterScreen">
    
    
   <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>


       
       
       <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Gestión de productos"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Button x:Name="BtnCargarProductosGestion"
                    Grid.Row="1"
                    Content="Cargar productos"
                    Width="140"
                    Height="32"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,10"
                    Click="BtnCargarProductosGestion_Click"/>

            <DataGrid x:Name="TablaProductosGestion"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="TablaProductosGestion_SelectionChanged">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Referencia" Binding="{Binding Referencia}" Width="120"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="160"/>
                    <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="120"/>
                    <DataGridTextColumn Header="Trazabilidad" Binding="{Binding TipoTrazabilidadNombre}" Width="120"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding PrecioVenta}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Habilitado" Binding="{Binding Habilitado}" Width="90"/>
                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Activo}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>


       
       <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="Datos del producto"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Referencia"/>
                <TextBox x:Name="TxtReferencia" Margin="0,0,0,8"/>

                <TextBlock Text="Nombre"/>
                <TextBox x:Name="TxtNombre" Margin="0,0,0,8"/>

                <TextBlock Text="Descripción"/>
                <TextBox x:Name="TxtDescripcion" Margin="0,0,0,8"/>

                <TextBlock Text="Categoría"/>
                <TextBox x:Name="TxtCategoria" Margin="0,0,0,8"/>

                <TextBlock Text="Precio coste"/>
                <TextBox x:Name="TxtPrecioCoste" Margin="0,0,0,8"/>

                <TextBlock Text="Precio venta"/>
                <TextBox x:Name="TxtPrecioVenta" Margin="0,0,0,8"/>

                <TextBlock Text="Stock mínimo"/>
                <TextBox x:Name="TxtStockMinimo" Margin="0,0,0,8"/>

                <TextBlock Text="Tipo de trazabilidad"/>
                <ComboBox x:Name="CmbTipoTrazabilidad"
                          DisplayMemberPath="Nombre"
                          SelectedValuePath="Id"
                          Margin="0,0,0,8"/>

                <CheckBox x:Name="ChkHabilitado"
                          Content="Habilitado para tienda"
                          Margin="0,5,0,5"/>

                <CheckBox x:Name="ChkActivo"
                          Content="Activo"
                          IsEnabled="False"
                          Margin="0,0,0,10"/>

                <TextBlock Text="Imagen URL"/>
                <TextBox x:Name="TxtImagenUrl" Margin="0,0,0,8"/>

                <TextBlock Text="Observaciones"/>
                <TextBox x:Name="TxtObservaciones"
                         Height="60"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Margin="0,0,0,12"/>

                <WrapPanel Margin="0,5,0,10">
                    <Button x:Name="BtnNuevoProducto"
                            Content="Nuevo"
                            Width="80"
                            Height="30"
                            Margin="0,0,5,5"
                            Click="BtnNuevoProducto_Click"/>

                    <Button x:Name="BtnGuardarProducto"
                            Content="Guardar"
                            Width="80"
                            Height="30"
                            Margin="0,0,5,5"
                            Click="BtnGuardarProducto_Click"/>

                    <Button x:Name="BtnEliminarProducto"
                            Content="Eliminar"
                            Width="80"
                            Height="30"
                            Margin="0,0,5,5"
                            Click="BtnEliminarProducto_Click"/>
                </WrapPanel>

                <TextBlock x:Name="TxtMensajeGestionProductos"
                           Text=""
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>