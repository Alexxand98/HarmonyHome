<Window x:Class="HarmonyHome.Wpf.Views.GestionUbicacionesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="GestionUbicacionesView" Height="500" Width="1000"
         WindowStartupLocation="CenterScreen">
    
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Gestion de ubicaciones"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Button x:Name="BtnCargarUbicaciones"
                    Grid.Row="1"
                    Content="Cargar ubicaciones"
                    Width="150"
                    Height="32"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,10"
                    Click="BtnCargarUbicaciones_Click"/>

            <DataGrid x:Name="TablaUbicaciones"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="TablaUbicaciones_SelectionChanged">


                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="120"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="220"/>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoUbicacionNombre}" Width="120"/>
                    <DataGridCheckBoxColumn Header="Activa" Binding="{Binding Activa}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StackPanel Grid.Column="1">

            <TextBlock Text="Datos de la ubicacion"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <TextBlock Text="Codigo"/>
            <TextBox x:Name="TxtCodigo" Margin="0,0,0,8"/>

            <TextBlock Text="Nombre"/>
            <TextBox x:Name="TxtNombre" Margin="0,0,0,8"/>

            <TextBlock Text="Tipo ubicacion"/>
            <ComboBox x:Name="CmbTipoUbicacion"
                      DisplayMemberPath="Nombre"
                      SelectedValuePath="Id" Margin="0,0,0,8"/>

            <CheckBox x:Name="ChkActiva"
                      Content="Activa"
                      Margin="0,5,0,15"/>

            <WrapPanel Margin="0,5,0,10">
                <Button x:Name="BtnNuevaUbicacion"
                        Content="Nueva"
                        Width="80"
                        Height="30"
                        Margin="0,0,5,5"
                        Click="BtnNuevaUbicacion_Click"/>

                <Button x:Name="BtnGuardarUbicacion"
                        Content="Guardar"
                        Width="80" Height="30"
                        Margin="0,0,5,5"
                        Click="BtnGuardarUbicacion_Click"/>


                <Button x:Name="BtnEliminarUbicacion"
                        Content="Eliminar"
                        Width="80" Height="30" Margin="0,0,5,5"
                       Click="BtnEliminarUbicacion_Click"/>
                
                
            </WrapPanel>

            <TextBlock x:Name="TxtMensajeGestionUbicaciones" Text=""
                       Foreground="Gray"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"/>

        </StackPanel>
    </Grid>
</Window>