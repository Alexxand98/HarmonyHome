<Window x:Class="HarmonyHome.Wpf.Views.GestionUbicacionesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="Gestión de ubicaciones"
        Height="700"
        Width="1150"
        MinHeight="620"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="22"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Gestión de ubicaciones"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Administra zonas, posiciones y ubicaciones utilizadas por el módulo logístico."
                           FontSize="14"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardPanel}"
                    Margin="0,0,14,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Listado de ubicaciones"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoPrincipal}"
                               Margin="0,0,0,12"/>

                    <Grid Grid.Row="1"
                          Margin="0,0,0,12">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnCargarUbicaciones"
                                Grid.Column="0"
                                Content="Cargar ubicaciones"
                                Width="160"
                                Click="BtnCargarUbicaciones_Click"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">

                            <TextBlock Text="Buscar"
                                       FontSize="13"
                                       Foreground="{StaticResource ColorTextoSecundario}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <TextBox x:Name="TxtBuscarUbicacion"
                                     Width="230"
                                     Margin="0,0,8,0"/>

                            <Button x:Name="BtnBuscarUbicacion"
                                    Content="Buscar"
                                    Width="85"
                                    Click="BtnBuscarUbicacion_Click"/>

                            <Button x:Name="BtnLimpiarBusquedaUbicacion"
                                    Content="Limpiar"
                                    Width="85"
                                    Style="{StaticResource BotonPeligro}"
                                    Click="BtnLimpiarBusquedaUbicacion_Click"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="TablaUbicaciones"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="TablaUbicaciones_SelectionChanged">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código"
                                                Binding="{Binding Codigo}"
                                                Width="140"/>

                            <DataGridTextColumn Header="Nombre"
                                                Binding="{Binding Nombre}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Tipo"
                                                Binding="{Binding TipoUbicacionNombre}"
                                                Width="160"/>

                            <DataGridCheckBoxColumn Header="Activa"
                                                    Binding="{Binding Activa}"
                                                    Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource CardPanel}">

                <StackPanel>
                    <TextBlock Text="Datos de la ubicación"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoPrincipal}"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="Código"
                               Foreground="{StaticResource ColorTextoSecundario}"/>
                    <TextBox x:Name="TxtCodigo" Margin="0,4,0,8"/>

                    <TextBlock Text="Nombre"
                               Foreground="{StaticResource ColorTextoSecundario}"/>
                    <TextBox x:Name="TxtNombre" Margin="0,4,0,8"/>

                    <TextBlock Text="Tipo ubicación"
                               Foreground="{StaticResource ColorTextoSecundario}"/>
                    <ComboBox x:Name="CmbTipoUbicacion"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              Margin="0,4,0,10"/>

                    <CheckBox x:Name="ChkActiva"
                              Content="Activa"
                              Margin="0,4,0,16"/>

                    <WrapPanel Margin="0,4,0,10">
                        <Button x:Name="BtnNuevaUbicacion"
                                Content="Nueva"
                                Width="85"
                                Click="BtnNuevaUbicacion_Click"/>

                        <Button x:Name="BtnGuardarUbicacion"
                                Content="Guardar"
                                Width="85"
                                Style="{StaticResource BotonOperacion}"
                                Click="BtnGuardarUbicacion_Click"/>

                        <Button x:Name="BtnEliminarUbicacion"
                                Content="Eliminar"
                                Width="85"
                                Style="{StaticResource BotonPeligro}"
                                Click="BtnEliminarUbicacion_Click"/>
                    </WrapPanel>

                    <TextBlock x:Name="TxtMensajeGestionUbicaciones"
                               Text=""
                               Style="{StaticResource TextoMensaje}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>