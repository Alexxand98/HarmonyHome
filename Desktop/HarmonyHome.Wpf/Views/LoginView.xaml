<Window x:Class="HarmonyHome.Wpf.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="400"
        Width="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="DarkSeaGreen"
            CornerRadius="20"
            Padding="30">

        <StackPanel>

            <TextBlock Text="HarmonyHome"
                       FontSize="30"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Acceso logística"
                       FontSize="15"
                       Foreground="{StaticResource ColorTextoPrincipal}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>

            <TextBlock Text="Email"
                       FontWeight="DemiBold"
                       Margin="0,0,0,10"/>

            <TextBox x:Name="TxtEmail"
                     Height="30"
                     Width="240"
                     Margin="0,0,0,15"/>

            <TextBlock Text="Contraseña"
                       FontWeight="DemiBold"
                       Margin="0,0,0,10"/>

            <PasswordBox x:Name="TxtPassword"
                         Height="30"
                         Width="240"
                         Margin="0,0,0,15"/>

            <TextBlock x:Name="TxtError"
                       Foreground="{StaticResource ColorTextoBotonPeligro}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,15"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,5,0,0">

                <Button x:Name="BtnSalirLogin"
                        Content="Salir"
                        Width="100"
                        Height="35"
                        Margin="10,0,10,0"
                        Style="{StaticResource BotonPeligro}"
                        Click="BtnSalir_Click"/>

                <Button x:Name="BtnEnterLogin"
                        Content="Iniciar sesion"
                        Width="100"
                        Height="35"
                        Margin="10,0,10,0"
                        Style="{StaticResource BotonOperacion}"
                        Click="BtnLogin_Click"/>

            </StackPanel>

        </StackPanel>

    </Border>
</Window>