<Window x:Class="HarmonyHome.Wpf.Views.MovimientoInternoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="Movimiento interno de stock"
        Height="580"
        Width="720"
        MinHeight="560"
        MinWidth="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="18"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,12">

            <StackPanel>
                <TextBlock Text="Movimiento interno de stock"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Mueve unidades de un producto entre dos ubicaciones del almacén."
                           FontSize="13"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardPanel}"
                Margin="0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.ColumnSpan="3"
                           Text="Datos del movimiento"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <StackPanel Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Margin="0,0,0,10">

                    <TextBlock Text="Producto"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <ComboBox x:Name="CmbProducto"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              Text="Seleccione un producto"
                              IsEditable="True"
                              IsReadOnly="True"
                              Margin="0,4,0,0"
                              SelectionChanged="CmbProducto_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,0,0,10">

                    <TextBlock Text="Ubicación origen"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <ComboBox x:Name="CmbOrigen"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              Text="Seleccione ubicación de origen"
                              IsEditable="True"
                              IsReadOnly="True"
                              Margin="0,4,0,0"
                              SelectionChanged="CmbOrigen_SelectionChanged"/>

                    <TextBlock x:Name="TxtStockDisponible"
                               Text="Stock disponible en origen: -"
                               FontSize="12"
                               Foreground="{StaticResource ColorTextoSecundario}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="2"
                            Margin="0,0,0,10">

                    <TextBlock Text="Ubicación destino"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <ComboBox x:Name="CmbDestino"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              Text="Seleccione ubicación de destino"
                              IsEditable="True"
                              IsReadOnly="True"
                              Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Grid.Column="0"
                            Width="180"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10">

                    <TextBlock Text="Cantidad"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <TextBox x:Name="TxtCantidad"
                             Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Grid.ColumnSpan="3">

                    <TextBlock Text="Observaciones"
                               Foreground="{StaticResource ColorTextoSecundario}"/>

                    <TextBox x:Name="TxtObservaciones"
                             Height="60"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Margin="0,4,0,10"/>

                    <Button x:Name="BtnMover"
                            Content="Mover stock"
                            Width="130"
                            Style="{StaticResource BotonOperacion}"
                            HorizontalAlignment="Left"
                            Click="BtnMover_Click"/>

                    <TextBlock x:Name="TxtMensaje"
                               Text=""
                               Foreground="{StaticResource ColorTextoSecundario}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>