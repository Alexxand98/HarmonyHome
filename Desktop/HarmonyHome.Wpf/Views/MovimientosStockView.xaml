<Window x:Class="HarmonyHome.Wpf.Views.MovimientosStockView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="Historial de movimientos"
        Height="650"
        Width="1150"
        MinHeight="580"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="22"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Historial de movimientos"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Consulta los movimientos de stock registrados entre ubicaciones y operaciones logísticas."
                           FontSize="14"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardPanel}"
                Margin="0,0,0,14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Acciones"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <Button x:Name="BtnActualizarMovimientos"
                        Grid.Row="1"
                        Content="Actualizar"
                        Width="110"
                        HorizontalAlignment="Left"
                        Click="BtnActualizarMovimientos_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardPanel}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Listado de movimientos"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <DataGrid x:Name="TablaMovimientos"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha"
                                            Binding="{Binding Fecha}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Referencia"
                                            Binding="{Binding ProductoReferencia}"
                                            Width="130"/>

                        <DataGridTextColumn Header="Producto"
                                            Binding="{Binding ProductoNombre}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Origen"
                                            Binding="{Binding UbicacionOrigenCodigo}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Destino"
                                            Binding="{Binding UbicacionDestinoCodigo}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Cantidad"
                                            Binding="{Binding Cantidad}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Tipo"
                                            Binding="{Binding TipoMovimientoNombre}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Observaciones"
                                            Binding="{Binding Observaciones}"
                                            Width="240"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <TextBlock x:Name="TxtMensajeMovimientos"
                   Grid.Row="3"
                   Text=""
                   Style="{StaticResource TextoMensaje}"/>
    </Grid>
</Window>