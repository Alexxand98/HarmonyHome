<Window x:Class="HarmonyHome.Wpf.Views.OrdenesRecogidaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="Órdenes de recogida"
        Height="720"
        Width="1200"
        MinHeight="650"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="22"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Órdenes de recogida"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Gestiona las órdenes generadas desde pedidos de cliente para su preparación logística."
                           FontSize="14"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardPanel}"
                Margin="0,0,0,14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Filtros y búsqueda"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0">
                        <Button x:Name="BtnCargarOrdenes"
                                Content="Cargar todas"
                                Width="120"
                                Click="BtnCargarOrdenes_Click"/>


                    </WrapPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">

                        <TextBlock Text="Buscar"
                                   FontSize="13"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <TextBox x:Name="TxtBuscarOrden"
                                 Width="250"
                                 Margin="0,0,8,0"/>

                        <Button x:Name="BtnBuscarOrden"
                                Content="Buscar"
                                Width="85"
                                Click="BtnBuscarOrden_Click"/>

                        <Button x:Name="BtnLimpiarBusquedaOrden"
                                Content="Limpiar"
                                Width="85"
                                Style="{StaticResource BotonPeligro}"
                                Click="BtnLimpiarBusquedaOrden_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardPanel}"
                Margin="0,0,0,14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Listado de órdenes"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <DataGrid x:Name="TablaOrdenes"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="TablaOrdenes_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id"
                                            Binding="{Binding Id}"
                                            Width="60"/>

                        <DataGridTextColumn Header="Pedido"
                                            Binding="{Binding PedidoVentaId}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Fecha"
                                            Binding="{Binding FechaCreacion}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Estado"
                                            Binding="{Binding EstadoNombre}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Asignado a"
                                            Binding="{Binding AsignadoTexto}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Cliente"
                                            Binding="{Binding ClienteNombreCompleto}"
                                            Width="180"/>

                        <DataGridTextColumn Header="Total"
                                            Binding="{Binding TotalPedido}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Observaciones"
                                            Binding="{Binding Observaciones}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Style="{StaticResource CardPanel}"
                Margin="0,0,0,14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Líneas del pedido"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <DataGrid x:Name="TablaLineas"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Referencia"
                                            Binding="{Binding ProductoReferencia}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Producto"
                                            Binding="{Binding ProductoNombre}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Cantidad"
                                            Binding="{Binding Cantidad}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Precio"
                                            Binding="{Binding PrecioUnitario}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Subtotal"
                                            Binding="{Binding Subtotal}"
                                            Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="5"
                Style="{StaticResource CardPanel}"
                Margin="0,0,0,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Acciones sobre la orden"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <WrapPanel Grid.Row="1">
                    <Button x:Name="BtnAsignar"
                            Content="Asignar"
                            Width="100"
                            Click="BtnAsignar_Click"/>

                    <Button x:Name="BtnPreparacion"
                            Content="Preparación"
                            Width="115"
                            Style="{StaticResource BotonOperacion}"
                            Click="BtnPreparacion_Click"/>

                    <Button x:Name="BtnVerPreparacion"
                            Content="Ver preparación"
                            Width="135"
                            Click="BtnVerPreparacion_Click"/>

                    <Button x:Name="BtnFinalizar"
                            Content="Finalizar"
                            Width="100"
                            Style="{StaticResource BotonOperacion}"
                            Click="BtnFinalizar_Click"/>

                    <Button x:Name="BtnCancelarOrden"
                            Content="Cancelar"
                            Width="100"
                            Style="{StaticResource BotonPeligro}"
                            Click="BtnCancelarOrden_Click"/>
                </WrapPanel>
            </Grid>
        </Border>

        <TextBlock x:Name="TxtMensaje"
                   Grid.Row="6"
                   Text=""
                   Style="{StaticResource TextoMensaje}"/>
    </Grid>
</Window>