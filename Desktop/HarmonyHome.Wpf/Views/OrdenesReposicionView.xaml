<Window x:Class="HarmonyHome.Wpf.Views.OrdenesReposicionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="OrdenesReposicionView" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Órdenes de reposición"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <Button x:Name="BtnCargarOrdenes"
                    Content="Cargar todas"
                    Width="120"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="BtnCargarOrdenes_Click"/>

            <Button x:Name="BtnCargarPendientes"
                    Content="Pendientes"
                    Width="120"
                    Height="32"
                    Click="BtnCargarPendientes_Click"/>
        </WrapPanel>

        <DataGrid x:Name="TablaOrdenes"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="TablaOrdenes_SelectionChanged">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaSolicitud}" Width="150"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding EstadoNombre}" Width="120"/>
                <DataGridTextColumn Header="Solicitante" Binding="{Binding UsuarioSolicitanteId}" Width="220"/>
                <DataGridTextColumn Header="Preparador" Binding="{Binding UsuarioPreparadorId}" Width="220"/>
                <DataGridTextColumn Header="Observaciones" Binding="{Binding Observaciones}" Width="220"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3"
                   Text="Líneas de reposición"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,12,0,8"/>

        <DataGrid x:Name="TablaLineas"
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Referencia" Binding="{Binding ProductoReferencia}" Width="130"/>
                <DataGridTextColumn Header="Producto" Binding="{Binding ProductoNombre}" Width="180"/>
                <DataGridTextColumn Header="Solicitada" Binding="{Binding CantidadSolicitada}" Width="100"/>
                <DataGridTextColumn Header="Preparada" Binding="{Binding CantidadPreparada}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="5" Margin="0,12,0,0">
            <Button x:Name="BtnAsignar"
                    Content="Asignar"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="BtnAsignar_Click"/>

            <Button x:Name="BtnFinalizar"
                    Content="Finalizar"
                    Width="100"
                    Height="32"
                    Click="BtnFinalizar_Click"/>
        </WrapPanel>

        <TextBlock x:Name="TxtMensaje"
                   Grid.Row="6"
                   Text=""
                   Foreground="Gray"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>