<Window x:Class="HarmonyHome.Wpf.Views.OrdenesReposicionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="Órdenes de reposición"
        Height="900"
        Width="1250"
        MinHeight="840"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="18"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,12">

            <StackPanel>
                <TextBlock Text="Órdenes de reposición"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Gestiona las solicitudes de reposición de stock entre tienda y almacén."
                           FontSize="13"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardPanel}"
                Margin="0,0,0,12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Filtros y búsqueda"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,10"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnActualizarOrdenes"
                            Grid.Column="0"
                            Content="Actualizar"
                            Width="110"
                            Click="BtnActualizarOrdenes_Click"/>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">

                        <TextBlock Text="Buscar"
                                   FontSize="13"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <TextBox x:Name="TxtBuscarOrden"
                                 Width="250"
                                 Margin="0,0,8,0"/>

                        <Button x:Name="BtnBuscarOrden"
                                Content="Buscar"
                                Width="85"
                                Click="BtnBuscarOrden_Click"/>

                        <Button x:Name="BtnLimpiarBusquedaOrden"
                                Content="Limpiar"
                                Width="85"
                                Style="{StaticResource BotonPeligro}"
                                Click="BtnLimpiarBusquedaOrden_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="1.25*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="1.15*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource CardPanel}">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Listado de órdenes"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoPrincipal}"
                               Margin="0,0,0,10"/>

                    <DataGrid x:Name="TablaOrdenes"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="TablaOrdenes_SelectionChanged">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id"
                                                Binding="{Binding Id}"
                                                Width="60"/>

                            <DataGridTextColumn Header="Fecha"
                                                Binding="{Binding FechaSolicitud}"
                                                Width="160"/>

                            <DataGridTextColumn Header="Estado"
                                                Binding="{Binding EstadoNombre}"
                                                Width="130"/>

                            <DataGridTextColumn Header="Solicitante"
                                                Binding="{Binding SolicitanteTexto}"
                                                Width="220"/>

                            <DataGridTextColumn Header="Preparador"
                                                Binding="{Binding PreparadorTexto}"
                                                Width="220"/>

                            <DataGridTextColumn Header="Observaciones"
                                                Binding="{Binding Observaciones}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource CardPanel}">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Líneas de reposición"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoPrincipal}"
                               Margin="0,0,0,10"/>

                    <DataGrid x:Name="TablaLineas"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Referencia"
                                                Binding="{Binding ProductoReferencia}"
                                                Width="150"/>

                            <DataGridTextColumn Header="Producto"
                                                Binding="{Binding ProductoNombre}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Solicitada"
                                                Binding="{Binding CantidadSolicitada}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Preparada"
                                                Binding="{Binding CantidadPreparada}"
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Style="{StaticResource CardPanel}"
                Margin="0,12,0,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Acciones sobre la orden"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,10"/>

                <WrapPanel Grid.Row="1">
                    <Button x:Name="BtnAsignar"
                            Content="Asignar"
                            Width="100"
                            Click="BtnAsignar_Click"/>

                    <Button x:Name="BtnVerPreparacion"
                            Content="Ver preparación"
                            Width="135"
                            Click="BtnVerPreparacion_Click"/>

                    <Button x:Name="BtnFinalizar"
                            Content="Finalizar"
                            Width="100"
                            Style="{StaticResource BotonOperacion}"
                            Click="BtnFinalizar_Click"/>

                    <Button x:Name="BtnCancelarOrden"
                            Content="Cancelar"
                            Width="100"
                            Style="{StaticResource BotonPeligro}"
                            Click="BtnCancelarOrden_Click"/>
                </WrapPanel>

                <TextBlock x:Name="TxtMensaje"
                           Grid.Row="2"
                           Text=""
                           Foreground="{StaticResource ColorTextoSecundario}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>