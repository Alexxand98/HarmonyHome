<Window x:Class="HarmonyHome.Wpf.Views.ProductoDetalleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle del producto"
        Height="600"
        Width="850"
        MinHeight="540"
        MinWidth="780"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="22"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Detalle del producto"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Información general, estado e imagen del producto seleccionado."
                           FontSize="14"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardPanel}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="{StaticResource ColorBorde}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12"
                        Height="280"
                        VerticalAlignment="Top">

                    <Image x:Name="ImgProducto"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto">

                    <StackPanel>
                        <TextBlock x:Name="TxtNombre"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorTextoPrincipal}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                        <TextBlock x:Name="TxtReferencia"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Descripción"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorTextoPrincipal}"
                                   Margin="0,0,0,4"/>

                        <TextBlock x:Name="TxtDescripcion"
                                   FontSize="14"
                                   Foreground="{StaticResource ColorTextoPrincipal}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"/>

                        <UniformGrid Columns="2"
                                     Margin="0,0,0,14">

                            <StackPanel Margin="0,0,12,10">
                                <TextBlock Text="Categoría"
                                           FontSize="12"
                                           Foreground="{StaticResource ColorTextoSecundario}"/>
                                <TextBlock x:Name="TxtCategoria"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Stock mínimo"
                                           FontSize="12"
                                           Foreground="{StaticResource ColorTextoSecundario}"/>
                                <TextBlock x:Name="TxtStockMinimo"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,12,10">
                                <TextBlock Text="Precio coste"
                                           FontSize="12"
                                           Foreground="{StaticResource ColorTextoSecundario}"/>
                                <TextBlock x:Name="TxtPrecioCoste"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Precio venta"
                                           FontSize="12"
                                           Foreground="{StaticResource ColorTextoSecundario}"/>
                                <TextBlock x:Name="TxtPrecioVenta"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,12,10">
                                <TextBlock Text="Trazabilidad"
                                           FontSize="12"
                                           Foreground="{StaticResource ColorTextoSecundario}"/>
                                <TextBlock x:Name="TxtTrazabilidad"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Estado"
                                           FontSize="12"
                                           Foreground="{StaticResource ColorTextoSecundario}"/>
                                <TextBlock x:Name="TxtEstado"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ColorTextoPrincipal}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="Observaciones"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ColorTextoPrincipal}"
                                   Margin="0,0,0,4"/>

                        <TextBlock x:Name="TxtObservaciones"
                                   FontSize="14"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Button Grid.Row="2"
                Content="Cerrar"
                Width="100"
                HorizontalAlignment="Right"
                Style="{StaticResource BotonPeligro}"
                Margin="0,14,0,0"
                Click="BtnCerrar_Click"/>
    </Grid>
</Window>