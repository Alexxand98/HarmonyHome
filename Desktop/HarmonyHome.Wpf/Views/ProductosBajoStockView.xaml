<Window x:Class="HarmonyHome.Wpf.Views.ProductosBajoStockView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productos bajo stock"
        Height="650"
        Width="1150"
        MinHeight="580"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="22"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Productos bajo stock"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Consulta productos activos cuyo stock total está por debajo o igual al stock mínimo configurado."
                           FontSize="14"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardPanel}"
                Margin="0,0,0,14">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnCargar"
                        Content="Cargar productos"
                        Width="150"
                        Click="BtnCargar_Click"/>

                <TextBlock x:Name="TxtResumen"
                           Grid.Column="1"
                           Text=""
                           FontSize="14"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardPanel}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Listado de productos"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <DataGrid x:Name="TablaProductosBajoStock"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Referencia"
                                            Binding="{Binding Referencia}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Nombre"
                                            Binding="{Binding Nombre}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Categoría"
                                            Binding="{Binding Categoria}"
                                            Width="160"/>

                        <DataGridTextColumn Header="Stock mínimo"
                                            Binding="{Binding StockMinimo}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Stock tienda"
                                            Binding="{Binding StockTienda}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Stock almacén"
                                            Binding="{Binding StockAlmacen}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Stock total"
                                            Binding="{Binding StockTotal}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Evaluación"
                                            Binding="{Binding TipoEvaluacion}"
                                            Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <TextBlock x:Name="TxtMensaje"
                   Grid.Row="3"
                   Text=""
                   Style="{StaticResource TextoMensaje}"/>
    </Grid>
</Window>