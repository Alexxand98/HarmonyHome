<Window x:Class="HarmonyHome.Wpf.Views.ProductosView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productos"
        Height="450"
        Width="850"
        WindowStartupLocation="CenterScreen">

    <Grid Background="White" Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Productos"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <WrapPanel Grid.Row="1" Margin="0,0,0,10">

            <Button x:Name="BtnCargarProductos"
                    Content="Cargar productos"
                    Width="130"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="BtnCargarProductos_Click"/>

            <TextBox x:Name="TxtBuscarProducto"
                     Width="220"
                     Height="32"
                     Margin="0,0,8,0"/>

            <Button x:Name="BtnBuscarProducto"
                    Content="Buscar"
                    Width="80"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="BtnBuscarProducto_Click"/>

            <Button x:Name="BtnLimpiarBusquedaProducto"
                    Content="Limpiar"
                    Width="80"
                    Height="32"
                    Click="BtnLimpiarBusquedaProducto_Click"/>

        </WrapPanel>

        <DataGrid x:Name="TablaProductos"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Referencia" Binding="{Binding Referencia}" Width="110"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="160"/>
                <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="120"/>
                <DataGridTextColumn Header="Trazabilidad" Binding="{Binding TipoTrazabilidadNombre}" Width="120"/>
                <DataGridTextColumn Header="Precio" Binding="{Binding PrecioVenta}" Width="80"/>
                <DataGridCheckBoxColumn Header="Habilitado" Binding="{Binding Habilitado}" Width="90"/>
                <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Activo}" Width="70"/>
            </DataGrid.Columns>

        </DataGrid>

        <TextBlock x:Name="TxtMensajeProductos"
                   Grid.Row="3"
                   Text=""
                   Foreground="Gray"
                   Margin="0,10,0,0"/>

    </Grid>
</Window>