<Window x:Class="HarmonyHome.Wpf.Views.ServidorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Servidor"
        Height="380"
        Width="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White"
            CornerRadius="25"
            Padding="25"
            BorderBrush="DarkSeaGreen"
            BorderThickness="5">

        <StackPanel>

            <TextBlock Text="Servidor"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>

            <TextBlock x:Name="TxtNombreApp"
                       Text="Aplicación:"
                       FontSize="14"
                       Margin="0,0,0,12"/>

            <TextBlock x:Name="TxtVersion"
                       Text="Versión:"
                       FontSize="14"
                       Margin="0,0,0,12"/>

            <TextBlock x:Name="TxtUsuarioServidor"
                       Text="Usuario:"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <TextBlock x:Name="TxtRolServidor"
                       Text="Rol:"
                       FontSize="14"
                       Margin="0,0,0,12"/>

            <TextBlock x:Name="TxtSesion"
                       Text="Sesión:"
                       FontSize="14"
                       Margin="0,0,0,25"/>

            <Button Content="Cerrar"
                    Height="32"
                    Width="90"
                    HorizontalAlignment="Center"
                    Click="BtnCerrarInfo_Click"/>

        </StackPanel>

    </Border>
</Window>