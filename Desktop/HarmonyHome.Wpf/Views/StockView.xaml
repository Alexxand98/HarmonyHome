<Window x:Class="HarmonyHome.Wpf.Views.StockView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="StockView" Height="500" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Consulta de stock"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <WrapPanel Grid.Row="1" Margin="0,0,0,10">

            
            <Button x:Name="BtnCargarTodo"
                    Content="Todo"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="BtnCargarTodo_Click"/>

            <Button x:Name="BtnCargarTienda"
                    Content="Tienda"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="BtnCargarTienda_Click"/>

            <Button x:Name="BtnCargarAlmacen"
                    Content="Almacén"
                    Width="100"
                    Height="32"
                    Click="BtnCargarAlmacen_Click"/>

            <Button x:Name="BtnMoverStock"
                    Content="Mover stock"
                    Width="110"
                    Height="32"
                    Margin="8,0,0,0"
                    Click="BtnMoverStock_Click"/>

            <Button x:Name="BtnAltaStock"
                    Content="Añadir stock"
                    Width="110"
                    Height="32"
                    Margin="8,0,0,0"
                    Click="BtnAltaStock_Click"/>
        </WrapPanel>

        <DataGrid x:Name="TablaStock"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Referencia" Binding="{Binding ProductoReferencia}" Width="130"/>
                <DataGridTextColumn Header="Producto" Binding="{Binding ProductoNombre}" Width="160"/>
                <DataGridTextColumn Header="Código ubicación" Binding="{Binding UbicacionCodigo}" Width="130"/>
                <DataGridTextColumn Header="Ubicación" Binding="{Binding UbicacionNombre}" Width="220"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoUbicacionNombre}" Width="100"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="TxtMensajeStock"
                   Grid.Row="3"
                   Text=""
                   Foreground="Gray"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>