<Window x:Class="HarmonyHome.Wpf.Views.StockView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="Consulta de stock"
        Height="650"
        Width="1150"
        MinHeight="580"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="22"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Consulta de stock"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Consulta las existencias disponibles por producto, ubicación y tipo de zona logística."
                           FontSize="14"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardPanel}"
                Margin="0,0,0,14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Filtros y acciones"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0"
                               VerticalAlignment="Center">

                        <Button x:Name="BtnCargarTodo"
                                Content="Actualizar"
                                Width="105"
                                Click="BtnCargarTodo_Click"/>

                        <Button x:Name="BtnCargarTienda"
                                Content="Tienda"
                                Width="95"
                                Click="BtnCargarTienda_Click"/>

                        <Button x:Name="BtnCargarAlmacen"
                                Content="Almacén"
                                Width="95"
                                Click="BtnCargarAlmacen_Click"/>

                        <Button x:Name="BtnMoverStock"
                                Content="Mover stock"
                                Width="120"
                                Click="BtnMoverStock_Click"/>

                        <Button x:Name="BtnAltaStock"
                                Content="Añadir stock"
                                Width="120"
                                Style="{StaticResource BotonOperacion}"
                                Click="BtnAltaStock_Click"/>
                    </WrapPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">

                        <TextBlock Text="Buscar"
                                   FontSize="13"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <TextBox x:Name="TxtBuscarStock"
                                 Width="250"
                                 Margin="0,0,8,0"/>

                        <Button x:Name="BtnBuscarStock"
                                Content="Buscar"
                                Width="85"
                                Click="BtnBuscarStock_Click"/>

                        <Button x:Name="BtnLimpiarBusquedaStock"
                                Content="Limpiar"
                                Width="85"
                                Style="{StaticResource BotonPeligro}"
                                Click="BtnLimpiarBusquedaStock_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardPanel}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Listado de stock"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <DataGrid x:Name="TablaStock"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Referencia"
                                            Binding="{Binding ProductoReferencia}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Producto"
                                            Binding="{Binding ProductoNombre}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Código ubicación"
                                            Binding="{Binding UbicacionCodigo}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Ubicación"
                                            Binding="{Binding UbicacionNombre}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Tipo"
                                            Binding="{Binding TipoUbicacionNombre}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Cantidad"
                                            Binding="{Binding Cantidad}"
                                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <TextBlock x:Name="TxtMensajeStock"
                   Grid.Row="3"
                   Text=""
                   Style="{StaticResource TextoMensaje}"/>
    </Grid>
</Window>