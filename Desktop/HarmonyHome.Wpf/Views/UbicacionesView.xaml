<Window x:Class="HarmonyHome.Wpf.Views.UbicacionesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HarmonyHome.Wpf.Views"
        mc:Ignorable="d"
        Title="Ubicaciones"
        Height="650"
        Width="1150"
        MinHeight="580"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoApp}">

    <Grid Margin="22"
          Background="{StaticResource ColorFondoApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ColorVerdePanel}"
                BorderBrush="{StaticResource ColorBorde}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Ubicaciones"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"/>

                <TextBlock Text="Consulta las zonas y posiciones disponibles dentro del flujo logístico."
                           FontSize="14"
                           Foreground="{StaticResource ColorTextoSecundario}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardPanel}"
                Margin="0,0,0,14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Filtros y acciones"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnCargarUbicaciones"
                            Grid.Column="0"
                            Content="Cargar ubicaciones"
                            Width="160"
                            Click="BtnCargarUbicaciones_Click"/>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">

                        <TextBlock Text="Buscar"
                                   FontSize="13"
                                   Foreground="{StaticResource ColorTextoSecundario}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <TextBox x:Name="TxtBuscarUbicacion"
                                 Width="250"
                                 Margin="0,0,8,0"/>

                        <Button x:Name="BtnBuscarUbicacion"
                                Content="Buscar"
                                Width="85"
                                Click="BtnBuscarUbicacion_Click"/>

                        <Button x:Name="BtnLimpiarBusquedaUbicacion"
                                Content="Limpiar"
                                Width="85"
                                Style="{StaticResource BotonPeligro}"
                                Click="BtnLimpiarBusquedaUbicacion_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardPanel}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Listado de ubicaciones"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorTextoPrincipal}"
                           Margin="0,0,0,12"/>

                <DataGrid x:Name="TablaUbicaciones"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código"
                                            Binding="{Binding Codigo}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Nombre"
                                            Binding="{Binding Nombre}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Tipo"
                                            Binding="{Binding TipoUbicacionNombre}"
                                            Width="180"/>

                        <DataGridCheckBoxColumn Header="Activa"
                                                Binding="{Binding Activa}"
                                                Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <TextBlock x:Name="TxtMensajeUbicaciones"
                   Grid.Row="3"
                   Text=""
                   Style="{StaticResource TextoMensaje}"/>
    </Grid>
</Window>